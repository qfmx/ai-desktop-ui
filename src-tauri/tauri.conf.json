{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI-Workspace",
  "mainBinaryName": "AI-Workspace",
  "version": "1.0.3",
  "identifier": "com.administrator.ai-desktop-ui",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4QTc1NEZFN0MwNjczN0YKUldSL2N3WjgvbFNuV0Q3NmFwYXh6STZKMzlWbTUwWkNtYWcwbWNVaStpMXFocjZsQ1dvblFYSVgK",
      "endpoints": [
        "https://github.com/qfmx/ai-desktop-ui/releases/latest/download/update.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI-Workspace",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "publisher": "Enterprise AI",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["zh-CN"],
        "upgradeCode": "f9e81b54-e257-4213-b6f1-e193420d9a8a"
      },
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "installMode": "both"
      }
    }
  }
}
